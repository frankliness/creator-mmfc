DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seedance"
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-pro-preview"
SEEDANCE_API_KEY=""
SEEDANCE_ENDPOINT=""
SEEDANCE_MODEL="dreamina-seedance-2-0-260128"
GCS_BUCKET="n8n-workflow-video"
GCS_PROJECT_ID=""
# 本地：指向 web 目录下的 service account JSON（勿提交到 git）
GOOGLE_APPLICATION_CREDENTIALS="./gcs-credentials.json"
# Docker：compose 已挂载到 /run/secrets/gcs-credentials.json，可省略或显式设置
VIDEO_STORAGE_PATH="./data/videos"
WORKER_POLL_INTERVAL="15000"

# v2.0.0：阿里云 OSS（Series 素材库长期公网存储）
# OSS bucket 需开启公网读 ACL 或使用预签名 URL，BytePlus CreateAsset 时会读取 ossPublicUrl
ALIYUN_OSS_REGION="oss-cn-shanghai"
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
# 自定义 endpoint，可选（默认基于 region 自动拼接）。例：https://oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ENDPOINT=""
# 公网访问域名（带协议），可选。未设置时由 SDK 根据 bucket + endpoint 推导
ALIYUN_OSS_PUBLIC_HOST=""

# v2.0.0：BytePlus Asset Library（资产同步给 Seedance 引用）
# Endpoint 与 Region 参考 BytePlus 控制台。Access Key 在 IAM 控制台获取
BYTEPLUS_ACCESS_KEY=""
BYTEPLUS_SECRET_KEY=""
BYTEPLUS_REGION="ap-southeast-1"
BYTEPLUS_ENDPOINT="https://open.byteplusapi.com"
BYTEPLUS_PROJECT_NAME="default"

# 邮箱验证码（注册 / 忘记密码）使用的 SMTP 配置。
# 常见示例：
#   QQ 企业邮箱：SMTP_HOST=smtp.exmail.qq.com  SMTP_PORT=465  SMTP_SECURE=true
#   阿里云邮件：SMTP_HOST=smtpdm.aliyun.com    SMTP_PORT=465  SMTP_SECURE=true
#   Gmail：     SMTP_HOST=smtp.gmail.com       SMTP_PORT=587  SMTP_SECURE=false
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
