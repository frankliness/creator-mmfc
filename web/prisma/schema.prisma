generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  name           String
  status         UserStatus      @default(ACTIVE)
  quota          Json?
  remark         String?         @db.Text
  projects         Project[]
  apiConfigs       UserApiConfig[]
  tokenUsages      TokenUsageLog[]
  actionLogs       UserActionLog[]
  canvasProjects   CanvasProject[]
  canvasImageTasks CanvasImageTask[]
  createdAt        DateTime        @default(now())
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

model Project {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  name              String
  script            String        @db.Text
  fullScript        String        @db.Text
  assetsJson        Json
  assetDescriptions Json
  style             String
  ratio             String        @default("9:16")
  resolution        String        @default("720p")
  seedanceEndpoint  String        @default("")
  globalSeed        Int                 @default(0)
  creationMode      ProjectCreationMode @default(AUTO)
  status            ProjectStatus       @default(DRAFT)
  storyboards       Storyboard[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
}

model Storyboard {
  id                   String           @id @default(uuid())
  projectId            String
  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storyboardId         String
  sortOrder            Int
  duration             Int
  seed                 Int?
  prompt               String           @db.Text
  assetBindings        Json
  seedanceContentItems Json
  status               StoryboardStatus @default(DRAFT)
  tasks                GenerationTask[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([projectId])
}

model GenerationTask {
  id               String         @id @default(uuid())
  storyboardId     String
  storyboard       Storyboard     @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  arkTaskId        String         @unique
  model            String
  status           TaskStatus     @default(SUBMITTED)
  arkStatus        String?
  videoUrl         String?        @db.Text
  localVideoPath   String?
  gcsVideoPath     String?
  seed             BigInt?
  resolution       String?
  ratio            String?
  duration         Int?
  completionTokens BigInt?
  totalTokens      BigInt?
  error            String?        @db.Text
  apiConfigId      String?
  apiConfig        UserApiConfig? @relation(fields: [apiConfigId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([storyboardId])
  @@index([status])
  @@index([apiConfigId])
}

model UserApiConfig {
  id           String              @id @default(uuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id])
  provider     String
  name         String
  endpoint     String
  apiKey       String
  model        String?
  /** 用途分类：video / chat / storyboard / canvas_image / canvas_image_edit。video 为旧默认（Seedance） */
  callType     String              @default("video")
  /** Azure OpenAI 专用：部署名（与 model 解耦） */
  deployment   String?
  /** Azure OpenAI 专用：api-version */
  apiVersion   String?
  /** 可选：指向共享 ProviderCredential。设置后 endpoint/apiKey 仍保留作为快照，但运行时优先用 credentialId 解出的最新凭据。 */
  credentialId String?
  credential   ProviderCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  isDefault    Boolean             @default(false)
  isActive     Boolean             @default(true)
  tasks        GenerationTask[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([userId])
  @@index([userId, provider])
  @@index([userId, callType, isDefault])
  @@index([credentialId])
}

/// admin 维护的共享凭据。每个 provider 类型可有多条；主用凭据按 provider + purposes + modelKeys 匹配。
model ProviderCredential {
  id             String          @id @default(uuid())
  /** 'openai' | 'azure_openai' | 'google' | 'custom' */
  provider       String
  /** 人类标签，如 "OpenAI 主号" / "Azure 测试" */
  name           String
  baseUrl        String
  /** AES 加密 */
  apiKey         String
  /** Azure OpenAI 专用：deployment 名 */
  deployment     String?
  /** Azure OpenAI 专用：api-version */
  apiVersion     String?
  /** 是否启用：禁用后凭据池查询会跳过 */
  isActive       Boolean         @default(true)
  /** 凭据适用业务类型：chat / storyboard / canvas_image / canvas_image_edit；为空兼容旧数据，视为全部适用 */
  purposes       Json?
  /** 凭据适用模型 key 列表；为空表示该业务类型下所有模型 */
  modelKeys      Json?
  /** 同 provider + purposes + modelKeys 范围内的"主用"凭据 */
  isPrimary      Boolean         @default(false)
  sortOrder      Int             @default(100)
  remark         String?
  /** 该渠道画布生图并发上限（仅 canvas_image / canvas_image_edit 调度使用；Azure gpt-image-2 实测约 6） */
  concurrency    Int             @default(6)
  /** 命中限流后的冷却到期时间；null 或已过期则参与调度。worker 调度时跳过未过期的渠道。 */
  cooldownUntil  DateTime?
  userApiConfigs UserApiConfig[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([provider, isActive])
  @@index([provider, isPrimary])
  @@index([isActive, cooldownUntil])
}

model ModelRegistry {
  id            String   @id @default(uuid())
  /** 调用接口时 body.model 的值，如 "gpt-4o" / "gemini-3-pro-image-preview" */
  modelKey      String
  /** 前端 dropdown 显示的人类友好名 */
  label         String
  /** 用途：chat / canvas_image / canvas_image_edit / storyboard */
  category      String
  /** 适用 provider 类型数组，如 ["openai","azure_openai"] */
  providers     Json
  /** 能力字段 JSON：{ imageGen, imageEdit, vision, tools, jsonSchema, jsonMode, streaming } 等布尔 */
  capabilities  Json
  /** 图片模型可选 size 列表（aspect ratio key），如 ["1:1","16:9","9:16"] */
  sizes         Json?
  /** 图片模型可选 quality 列表，如 [{label:"HD",key:"hd"},...] */
  qualities     Json?
  /** 默认参数 { size, quality } */
  defaultParams Json?
  /** 鼠标悬停提示 */
  tips          String?  @db.Text
  /** 是否启用：禁用后画布前端不再显示 */
  isActive      Boolean  @default(true)
  /** 排序权重，小的在前 */
  sortOrder     Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([modelKey, category])
  @@index([category, isActive, sortOrder])
}

model GlobalConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  encrypted Boolean  @default(false)
  remark    String?
  updatedAt DateTime @updatedAt
}

model TokenUsageLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  projectId    String?
  taskId       String?
  provider     String
  model        String
  requestType  String
  inputTokens  BigInt   @default(0)
  outputTokens BigInt   @default(0)
  totalTokens  BigInt   @default(0)
  costEstimate Decimal? @db.Decimal(10, 6)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, provider])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model UserActionLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  category     String
  action       String
  targetType   String
  targetId     String?
  projectId    String?
  storyboardId String?
  taskId       String?
  route        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([category])
  @@index([action])
  @@index([targetType])
  @@index([projectId])
  @@index([taskId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model PromptTemplate {
  id                  String          @id @default(uuid())
  name                String
  slug                String
  category            PromptCategory
  description         String?         @db.Text
  content             String          @db.Text
  /** JSON 数组，列出该条目适用于哪些 provider（如 ["openai","azure_openai"]）；null = 通用，所有 provider 都生效 */
  applicableProviders Json?
  version             Int             @default(1)
  isActive            Boolean         @default(true)
  versions            PromptVersion[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([slug, isActive])
}

enum PromptCategory {
  SYSTEM_PROMPT
  JSON_SCHEMA
  USER_PROMPT
}

model PromptVersion {
  id         String         @id @default(uuid())
  templateId String
  template   PromptTemplate @relation(fields: [templateId], references: [id])
  version    Int
  content    String         @db.Text
  changeNote String?
  createdBy  String?
  createdAt  DateTime       @default(now())

  @@index([templateId])
  @@unique([templateId, version])
}

enum ProjectCreationMode {
  AUTO
  MANUAL
}

enum ProjectStatus {
  DRAFT
  GENERATING_STORYBOARDS
  REVIEW
  GENERATING_VIDEOS
  COMPLETED
  FAILED
}

enum StoryboardStatus {
  DRAFT
  APPROVED
  SUBMITTED
  GENERATING
  SUCCEEDED
  FAILED
}

enum TaskStatus {
  SUBMITTED
  RUNNING
  SUCCEEDED
  FAILED
  PERSISTING
  PERSISTED
}

// ──────────────────────────────────────────────
// Canvas module (MMFC-canvas integration)
// ──────────────────────────────────────────────

model CanvasProject {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  name       String
  thumbnail  String?           @db.Text
  viewport   Json              @default("{\"x\":100,\"y\":50,\"zoom\":0.8}")
  status     CanvasStatus      @default(ACTIVE)
  nodes      CanvasNode[]
  edges      CanvasEdge[]
  assets     CanvasAsset[]
  aiCalls    CanvasAiCall[]
  imageTasks CanvasImageTask[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([userId])
  @@index([userId, updatedAt])
}

enum CanvasStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model CanvasNode {
  id        String
  projectId String
  project   CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  position  Json
  data      Json
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@id([projectId, id])
  @@index([projectId])
}

model CanvasEdge {
  id           String
  projectId    String
  project      CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source       String
  target       String
  sourceHandle String?
  targetHandle String?
  type         String?
  data         Json?

  @@id([projectId, id])
  @@index([projectId])
}

model CanvasAsset {
  id           String          @id @default(uuid())
  projectId    String
  project      CanvasProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId       String
  kind         CanvasAssetKind
  mimeType     String
  bytes        Int
  localPath    String?
  gcsPath      String?
  publicUrl    String?         @db.Text
  sourceNodeId String?
  createdAt    DateTime        @default(now())

  @@index([projectId])
  @@index([userId])
}

enum CanvasAssetKind {
  GENERATED_IMAGE
  UPLOADED_IMAGE
  GENERATED_VIDEO
}

model CanvasAiCall {
  id           String         @id @default(uuid())
  projectId    String?
  project      CanvasProject? @relation(fields: [projectId], references: [id])
  userId       String
  callType     String
  provider     String         @default("gemini-canvas")
  model        String
  inputTokens  BigInt         @default(0)
  outputTokens BigInt         @default(0)
  totalTokens  BigInt         @default(0)
  imageCount   Int            @default(0)
  durationMs   Int?
  costEstimate Decimal?       @db.Decimal(10, 6)
  /** status: success / failed / rate_limited（v1.5.0 起新增 rate_limited 用于看板，不算配额消耗） */
  status       String
  error        String?        @db.Text
  /** 实际分发的渠道（仅 canvas_image* 调用且 worker 抢占成功时回填）；用于渠道看板聚合 */
  credentialId String?
  createdAt    DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([projectId])
  @@index([credentialId, createdAt])
}

/// 画布图片生成任务（v1.4.0 起异步化）。
/// 状态机：PENDING → RUNNING → SUCCEEDED / FAILED。
/// 长 fetch（gpt-image-1 / 慢 Gemini）在 Worker 中执行，前端通过轮询恢复结果。
model CanvasImageTask {
  id                 String        @id @default(uuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  projectId          String
  project            CanvasProject @relation(fields: [projectId], references: [id])
  /** 触发该任务的画布节点（可选，用于"resume on refresh"） */
  sourceNodeId       String?
  /** PENDING / RUNNING / SUCCEEDED / FAILED */
  status             String        @default("PENDING")
  /** 调用用途：canvas_image / canvas_image_edit */
  callType           String
  /** 输入：模型 + 凭据偏好 + 提示词 */
  model              String
  /**
   * 凭据 id。语义双重：
   *   - API 建任务时携带 → 用户/管理员显式偏好（admin / 调试场景）
   *   - worker 渠道轮询抢占时回填 → 实际分发到的渠道（看板/审计依据）
   * 限流回退时会被清空，让任务回到 PENDING 由其他渠道接手。
   */
  credentialId       String?
  prompt             String        @db.Text
  size               String?
  quality            String?
  /** 是否图生图（参考图非空） */
  isEdit             Boolean       @default(false)
  /** 参考图的输入快照（asset paths / data URLs / http URLs）；worker 取出后再 normalize 成 base64 调用 provider */
  refImagesSnapshot  Json?
  /** 实际命中的 provider（worker 解析凭据后回填，便于审计/重试时定位） */
  upstreamProvider   String?
  /** 结果：CanvasAsset.id 数组（成功时） */
  resultAssetIds     Json?
  revisedPrompt      String?       @db.Text
  /** USD 估算（与 CanvasAiCall.costEstimate 一致；保留一份方便任务页直接看） */
  costEstimate       Decimal?      @db.Decimal(10, 6)
  durationMs         Int?
  error              String?       @db.Text
  /** 重试计数（worker 抢占时 +1） */
  attempts           Int           @default(0)
  /** 失败原因分类（status=FAILED 时填）：rate_limit / provider_error / timeout / other */
  failureKind        String?
  /**
   * 是否绕过渠道轮询：
   *   - 用户级 UserApiConfig 命中 canvas_image* 时为 true（用户私 key 不进共享池）
   *   - 全局 canvas_image_rotation_enabled=false 时为 true
   * worker 对 bypassRotation=true 的任务走旧逻辑：只受全局+用户并发约束，不占渠道并发位。
   */
  bypassRotation     Boolean       @default(false)
  /** 限流回退累计次数（worker 抢占处不增；image-task-runner 命中 429 时 +1）。硬上限 5 防热循环。 */
  cooldownRetries    Int           @default(0)
  startedAt          DateTime?
  finishedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([userId, status])
  @@index([projectId, status, createdAt])
  @@index([status, createdAt])
  @@index([credentialId, finishedAt])
}
