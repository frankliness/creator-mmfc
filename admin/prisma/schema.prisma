generator client {
  provider = "prisma-client-js"
  // 固定到 admin/server，避免本地 prisma generate 写入 admin/node_modules 而 tsc 仍读 server 下旧 client
  output   = "../server/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Existing models (kept in sync with user-side)
// ──────────────────────────────────────────────

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  name           String
  status         UserStatus      @default(ACTIVE)
  quota          Json?
  remark         String?         @db.Text
  /** 邮箱验证完成时间。null = 尚未通过邮箱验证。 */
  emailVerified  DateTime?
  /** v1.9.0: 是否允许自建 Project（旧用户保留 true；新用户默认 false） */
  canSelfCreateProject Boolean   @default(false)
  /** v1.9.1: 当前有效 Web 端 session id。新登录会改写此值，旧 token 失效（单设备登录）。 */
  activeSessionId String?
  projects         Project[]
  apiConfigs       UserApiConfig[]
  tokenUsages      TokenUsageLog[]
  actionLogs       UserActionLog[]
  canvasProjects   CanvasProject[]
  canvasImageTasks CanvasImageTask[]
  createdAt        DateTime        @default(now())
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

/// 邮箱验证码记录。用于注册和忘记密码两个流程。
/// - codeHash: 6 位数字验证码的 bcrypt 哈希（不存明文）
/// - purpose: REGISTER / RESET_PASSWORD
/// - expiresAt: 创建后 10 分钟过期
/// - consumedAt: 成功核销时间，已核销不可复用
/// - attempts: 校验次数，>=5 视为失效，防爆破
model EmailVerificationCode {
  id          String                       @id @default(uuid())
  email       String
  codeHash    String
  purpose     EmailVerificationCodePurpose
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int                          @default(0)
  createdAt   DateTime                     @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

enum EmailVerificationCodePurpose {
  REGISTER
  RESET_PASSWORD
}

model Project {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  name              String
  script            String              @db.Text
  fullScript        String              @db.Text
  assetsJson        Json
  assetDescriptions Json
  style             String
  ratio             String              @default("9:16")
  resolution        String              @default("720p")
  seedanceEndpoint  String              @default("")
  globalSeed        Int                 @default(0)
  creationMode      ProjectCreationMode @default(AUTO)
  status            ProjectStatus       @default(DRAFT)
  storyboards       Storyboard[]
  // v1.9.0: Series / Episode extensions
  seriesId          String?
  episodeNumber     Int?
  episodeTitle      String?
  assigneeId        String?
  lockedReason      String?             @db.Text
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([userId])
  @@index([seriesId])
}

enum ProjectCreationMode {
  AUTO
  MANUAL
}

enum ProjectStatus {
  DRAFT
  GENERATING_STORYBOARDS
  REVIEW
  GENERATING_VIDEOS
  COMPLETED
  FAILED
}

model Storyboard {
  id                   String           @id @default(uuid())
  projectId            String
  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storyboardId         String
  sortOrder            Int
  duration             Int
  seed                 Int?
  prompt               String           @db.Text
  assetBindings        Json
  seedanceContentItems Json
  status               StoryboardStatus @default(DRAFT)
  tasks                GenerationTask[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([projectId])
}

enum StoryboardStatus {
  DRAFT
  APPROVED
  SUBMITTED
  GENERATING
  SUCCEEDED
  FAILED
}

model GenerationTask {
  id               String         @id @default(uuid())
  storyboardId     String
  storyboard       Storyboard     @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  arkTaskId        String         @unique
  model            String
  status           TaskStatus     @default(SUBMITTED)
  arkStatus        String?
  videoUrl         String?        @db.Text
  localVideoPath   String?
  gcsVideoPath     String?
  seed             BigInt?
  resolution       String?
  ratio            String?
  duration         Int?
  completionTokens BigInt?
  totalTokens      BigInt?
  error            String?        @db.Text
  apiConfigId      String?
  apiConfig        UserApiConfig? @relation(fields: [apiConfigId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([storyboardId])
  @@index([status])
  @@index([apiConfigId])
}

enum TaskStatus {
  SUBMITTED
  RUNNING
  SUCCEEDED
  FAILED
  PERSISTING
  PERSISTED
}

// ──────────────────────────────────────────────
// Admin-only models
// ──────────────────────────────────────────────

model AdminUser {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String
  displayName  String
  role         AdminRole  @default(OPERATOR)
  isActive     Boolean    @default(true)
  // 分栏权限矩阵；SUPER_ADMIN 不依赖此字段，普通管理员未授权字段视为无权限
  permissions  Json?
  // 软删除时间；非空即视为已删除。登录/refresh/profile 必须过滤 deletedAt = null
  deletedAt    DateTime?
  lastLoginAt  DateTime?
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([deletedAt])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

model UserApiConfig {
  id           String              @id @default(uuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id])
  provider     String
  name         String
  endpoint     String
  apiKey       String
  model        String?
  /** 用途分类：video / chat / storyboard / canvas_image / canvas_image_edit。video 为旧默认（Seedance） */
  callType     String              @default("video")
  /** Azure OpenAI 专用：部署名（与 model 解耦） */
  deployment   String?
  /** Azure OpenAI 专用：api-version */
  apiVersion   String?
  /** 可选：指向共享 ProviderCredential。设置后运行时优先用该共享凭据。 */
  credentialId String?
  credential   ProviderCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  isDefault    Boolean             @default(false)
  isActive     Boolean             @default(true)
  tasks        GenerationTask[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([userId])
  @@index([userId, provider])
  @@index([userId, callType, isDefault])
  @@index([credentialId])
}

/// admin 维护的共享凭据。每个 provider 类型可有多条；主用凭据按 provider + purposes + modelKeys 匹配。
model ProviderCredential {
  id             String          @id @default(uuid())
  provider       String
  name           String
  baseUrl        String
  apiKey         String
  deployment     String?
  apiVersion     String?
  isActive       Boolean         @default(true)
  purposes       Json?
  modelKeys      Json?
  isPrimary      Boolean         @default(false)
  sortOrder      Int             @default(100)
  remark         String?
  /** v1.5.0: 每渠道默认画布生图并发上限（modelKey 未列入 concurrencyByModel 时使用） */
  concurrency    Int             @default(6)
  /** v1.9.1: 按模型独立并发上限，形如 { "seedream-4-0": 4, "gpt-image-1": 10 } */
  concurrencyByModel Json?
  /** v1.5.0: 命中限流后的冷却到期时间；null 或已过期则参与调度 */
  cooldownUntil  DateTime?
  userApiConfigs UserApiConfig[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([provider, isActive])
  @@index([provider, isPrimary])
  @@index([isActive, cooldownUntil])
}

model ModelRegistry {
  id            String   @id @default(uuid())
  /** 调用接口时 body.model 的值，如 "gpt-4o" / "gemini-3-pro-image-preview" */
  modelKey      String
  /** 前端 dropdown 显示的人类友好名 */
  label         String
  /** 用途：chat / canvas_image / canvas_image_edit / storyboard */
  category      String
  /** 适用 provider 类型数组 */
  providers     Json
  /** 能力字段 JSON */
  capabilities  Json
  sizes         Json?
  qualities     Json?
  defaultParams Json?
  tips          String?  @db.Text
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([modelKey, category])
  @@index([category, isActive, sortOrder])
}

model GlobalConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  encrypted Boolean  @default(false)
  remark    String?
  updatedAt DateTime @updatedAt
}

model TokenUsageLog {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  projectId         String?
  taskId            String?
  provider          String
  model             String
  requestType       String
  inputTokens       BigInt    @default(0)
  outputTokens      BigInt    @default(0)
  totalTokens       BigInt    @default(0)
  costEstimate      Decimal?  @db.Decimal(10, 6)
  metadata          Json?
  // v1.9.0: Resource budget tracking
  seriesId          String?
  seriesBudgetId    String?
  storyboardId      String?
  generationTaskId  String?
  canvasProjectId   String?
  canvasImageTaskId String?
  metricType        String?
  budgetScope       String?
  actualCallType    String?
  estimateTokens    BigInt    @default(0)
  actualTokens      BigInt    @default(0)
  reservedAmount    BigInt    @default(0)
  committedAmount   BigInt    @default(0)
  status            String    @default("FINALIZED")
  idempotencyKey    String?   @unique
  finalizedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([userId, provider])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([seriesId, createdAt])
  @@index([seriesBudgetId])
  @@index([status])
  @@index([generationTaskId])
  @@index([canvasImageTaskId])
}

model UserActionLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  category     String
  action       String
  targetType   String
  targetId     String?
  projectId    String?
  storyboardId String?
  taskId       String?
  route        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([category])
  @@index([action])
  @@index([targetType])
  @@index([projectId])
  @@index([taskId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model PromptTemplate {
  id                  String          @id @default(uuid())
  name                String
  slug                String
  category            PromptCategory
  description         String?         @db.Text
  content             String          @db.Text
  /** JSON 数组，列出该条目适用于哪些 provider（如 ["openai","azure_openai"]）；null = 通用，所有 provider 都生效 */
  applicableProviders Json?
  version             Int             @default(1)
  isActive            Boolean         @default(true)
  versions            PromptVersion[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([slug, isActive])
}

enum PromptCategory {
  SYSTEM_PROMPT
  JSON_SCHEMA
  USER_PROMPT
}

model PromptVersion {
  id         String         @id @default(uuid())
  templateId String
  template   PromptTemplate @relation(fields: [templateId], references: [id])
  version    Int
  content    String         @db.Text
  changeNote String?
  createdBy  String?
  createdAt  DateTime       @default(now())

  @@index([templateId])
  @@unique([templateId, version])
}

model AuditLog {
  id         String    @id @default(uuid())
  adminId    String
  admin      AdminUser @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String?
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Canvas module (MMFC-canvas integration)
// ──────────────────────────────────────────────

model CanvasProject {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  name       String
  thumbnail  String?           @db.Text
  viewport   Json              @default("{\"x\":100,\"y\":50,\"zoom\":0.8}")
  status     CanvasStatus      @default(ACTIVE)
  /** v1.9.0: 归属的 Series（项目）。null = legacy 个人画布 */
  seriesId   String?
  /** v1.9.1: 乐观锁版本号 */
  version    Int               @default(1)
  nodes      CanvasNode[]
  edges      CanvasEdge[]
  assets     CanvasAsset[]
  aiCalls    CanvasAiCall[]
  imageTasks CanvasImageTask[]
  history    CanvasSnapshotHistory[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([userId])
  @@index([userId, updatedAt])
  @@index([seriesId])
}

/// v1.9.1：画布快照历史
model CanvasSnapshotHistory {
  id         String        @id @default(uuid())
  projectId  String
  project    CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version    Int
  nodesJson  Json
  edgesJson  Json
  viewportJson Json
  nodeCount  Int
  edgeCount  Int
  userId     String?
  userAgent  String?       @db.Text
  ipAddress  String?
  clientId   String?
  createdAt  DateTime      @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, version])
}

enum CanvasStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model CanvasNode {
  id        String
  projectId String
  project   CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  position  Json
  data      Json
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@id([projectId, id])
  @@index([projectId])
}

model CanvasEdge {
  id           String
  projectId    String
  project      CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source       String
  target       String
  sourceHandle String?
  targetHandle String?
  type         String?
  data         Json?

  @@id([projectId, id])
  @@index([projectId])
}

model CanvasAsset {
  id           String          @id @default(uuid())
  projectId    String
  project      CanvasProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId       String
  kind         CanvasAssetKind
  mimeType     String
  bytes        Int
  localPath    String?
  gcsPath      String?
  publicUrl    String?         @db.Text
  sourceNodeId String?
  createdAt    DateTime        @default(now())

  @@index([projectId])
  @@index([userId])
}

enum CanvasAssetKind {
  GENERATED_IMAGE
  UPLOADED_IMAGE
  GENERATED_VIDEO
}

model CanvasAiCall {
  id           String         @id @default(uuid())
  projectId    String?
  project      CanvasProject? @relation(fields: [projectId], references: [id])
  userId       String
  callType     String
  provider     String         @default("gemini-canvas")
  model        String
  inputTokens  BigInt         @default(0)
  outputTokens BigInt         @default(0)
  totalTokens  BigInt         @default(0)
  imageCount   Int            @default(0)
  durationMs   Int?
  costEstimate Decimal?       @db.Decimal(10, 6)
  /** status: success / failed / rate_limited（v1.5.0 起新增 rate_limited） */
  status       String
  error        String?        @db.Text
  /** v1.5.0: 实际分发的渠道凭据 id，渠道看板按此聚合 */
  credentialId String?
  createdAt    DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([projectId])
  @@index([credentialId, createdAt])
}

/// 画布图片生成任务（v1.4.0 起异步化）。
model CanvasImageTask {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  projectId         String
  project           CanvasProject @relation(fields: [projectId], references: [id])
  sourceNodeId      String?
  status            String        @default("PENDING")
  callType          String
  model             String
  credentialId      String?
  prompt            String        @db.Text
  size              String?
  quality           String?
  isEdit            Boolean       @default(false)
  refImagesSnapshot Json?
  upstreamProvider  String?
  resultAssetIds    Json?
  revisedPrompt     String?       @db.Text
  costEstimate      Decimal?      @db.Decimal(10, 6)
  durationMs        Int?
  error             String?       @db.Text
  attempts          Int           @default(0)
  /** v1.5.0: 失败原因分类 rate_limit / provider_error / timeout / other */
  failureKind       String?
  /** v1.5.0: 绕过渠道轮询（用户级 UserApiConfig 命中或 rotation 关闭时为 true） */
  bypassRotation    Boolean       @default(false)
  /** v1.5.0: 限流回退累计次数，硬上限 5 防热循环 */
  cooldownRetries   Int           @default(0)
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId, status])
  @@index([projectId, status, createdAt])
  @@index([status, createdAt])
  @@index([credentialId, finishedAt])
}

// ──────────────────────────────────────────────
// v1.9.0: Series / 项目成员 / 资源预算
// ──────────────────────────────────────────────

/// v1.9.0：项目（产品语义）。承载多集数（Project / Episode）、成员、资源预算。
model Series {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  /** Series Owner / 导演 userId */
  ownerId     String?
  /** ACTIVE / LOCKED / OVER_BUDGET / ARCHIVED */
  status      String   @default("ACTIVE")
  /** v1.9.1：Series 全局默认设置（仅导演可改），集数创建/更新时下发到 Project */
  defaultStyle      String @default("")
  defaultRatio      String @default("9:16")
  defaultResolution String @default("720p")
  /** 0 = 每个集数生成时使用随机 seed；非 0 = 全 Series 统一 seed（不推荐） */
  defaultSeed       Int    @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
}

/// v1.9.0：项目组成员（Series 层级）。
model ProjectMember {
  id        String   @id @default(uuid())
  seriesId  String
  userId    String
  /** OWNER / PRODUCER / VIEWER */
  role      String   @default("PRODUCER")
  /** ACTIVE / REMOVED */
  status    String   @default("ACTIVE")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seriesId, userId])
  @@index([userId])
  @@index([seriesId])
  @@index([userId, status])
}

/// v1.9.0：集数级权限 override（仅建表，业务暂不接入）。
model ProjectMemberEpisodeOverride {
  id         String   @id @default(uuid())
  seriesId   String
  projectId  String
  userId     String
  /** READ_ONLY / DENY / EDIT */
  permission String
  grantedBy  String?
  reason     String?  @db.Text
  createdAt  DateTime @default(now())

  @@unique([projectId, userId, permission])
  @@index([seriesId, userId])
  @@index([projectId])
}

/// v1.9.0：Series 资源预算池。按 provider+modelKey+budgetScope+metricType 唯一。
model SeriesResourceBudget {
  id                String   @id @default(uuid())
  seriesId          String
  provider          String
  modelKey          String
  /** 预算口径：video_generation / canvas_image_generation 等 */
  budgetScope       String
  /** TOKEN / SUCCESS_COUNT */
  metricType        String
  totalBudget       BigInt   @default(0)
  committedUsage    BigInt   @default(0)
  reservedUsage     BigInt   @default(0)
  unallocatedBudget BigInt   @default(0)
  isHardCap         Boolean  @default(true)
  /** ACTIVE / EXHAUSTED / LOCKED / OVERRUN / ARCHIVED */
  status            String   @default("ACTIVE")
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([seriesId, provider, modelKey, budgetScope, metricType])
  @@index([seriesId])
  @@index([seriesId, budgetScope, modelKey])
  @@index([status])
}

/// v1.9.0：Series 预算 → 集数（Project）的分配。
model ProjectResourceAllocation {
  id              String   @id @default(uuid())
  seriesBudgetId  String
  seriesId        String
  projectId       String
  allocatedBudget BigInt   @default(0)
  committedUsage  BigInt   @default(0)
  reservedUsage   BigInt   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([seriesBudgetId, projectId])
  @@index([seriesId, projectId])
  @@index([projectId])
}

/// v1.9.0：预算变更事件流水。所有 budget 写动作都必须落一条。
model BudgetEvent {
  id                String   @id @default(uuid())
  seriesId          String
  seriesBudgetId    String?
  projectId         String?
  /** SERIES_BUDGET_CREATE / SERIES_BUDGET_INCREASE / SERIES_BUDGET_DECREASE / BUFFER_ALLOCATE / BUFFER_RELEASE / PROJECT_ALLOCATE / PROJECT_DEDUCT / OWNER_ADJUST / ADMIN_ADJUST / USAGE_RESERVE / USAGE_COMMIT / USAGE_RELEASE / USAGE_OVERRUN */
  type              String
  metricType        String?
  amount            BigInt
  beforeBudget      BigInt?
  afterBudget       BigInt?
  beforeUnallocated BigInt?
  afterUnallocated  BigInt?
  /** Admin 操作时为 AdminUser.id，Owner/Producer 时为 User.id */
  operatorId        String?
  /** ADMIN / OWNER / PRODUCER / SYSTEM */
  operatorRole      String?
  reason            String?  @db.Text
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([seriesId, createdAt])
  @@index([seriesBudgetId, createdAt])
  @@index([projectId, createdAt])
  @@index([type, createdAt])
}
