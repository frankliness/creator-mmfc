# 复制为仓库根目录的 .env 后由 docker compose 读取
# cp .env.docker.example .env

# ---------- 数据库 ----------
DB_PASSWORD=请替换为强密码
# db-init 执行 prisma db push。若 Postgres 卷是旧库、与当前 schema 漂移，可能报错要求
# --accept-data-loss（例如提示将删除 UserActionLog）。优先尝试：
#   docker compose build --no-cache db-init && docker compose up -d
# 仅本地开发库可设为 1，允许 push 按 Prisma 提示丢弃冲突表/数据（勿用于生产）。
# PRISMA_ACCEPT_DATA_LOSS=1
# db-init 是否从代码执行 seed-prompts（会按代码更新库内 Prompt 模板）。默认不配或 0=跳过，保留库内已有文案。
# SEED_PROMPTS_FROM_CODE=0

# ---------- 用户端（Next.js + NextAuth）----------
# 内网访问示例：http://192.168.1.100:3000（须与实际浏览器地址一致）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=请使用 openssl rand -base64 32 生成
# 生产镜像 NODE_ENV=production 时，用内网 IP 访问需开启（本 compose 默认 true）
AUTH_TRUST_HOST=true
WEB_PORT=3000

# 与用户端、管理端共用，用于加解密 UserApiConfig / GlobalConfig（≥32 字符，勿随意更换）
ENCRYPTION_KEY=请使用 openssl rand -hex 16 生成至少32字符

# ---------- Gemini / Seedance ----------
# GEMINI_API_KEY 同时用于：分镜 LLM、画布聊天、画布 Gemini Image。
# 后端会优先读 admin 端 GlobalConfig 中的 gemini_api_key，环境变量是兜底。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
SEEDANCE_API_KEY=
# 控制台/供应商提供的 Endpoint，勿使用他人或已泄露的示例值
SEEDANCE_ENDPOINT=
SEEDANCE_MODEL=dreamina-seedance-2-0-260128

# ---------- AI 画布（MMFC-canvas 集成模块）----------
# 画布生成 / 上传图片在容器内的存储路径，会通过 docker volume `canvas_images` 持久化。
# 注：资产对外访问统一走鉴权接口 GET /api/canvas/assets/:id，无需暴露真实文件路径。
# Nginx 反代请放行：用户入口 /ai-canvas、Vue 静态与深链 /canvas/*、API /api/canvas/*。
IMAGE_STORAGE_PATH=/data/canvas-images

# ---------- 可选：GCS 上传（不配置则仅本地 /data/videos）----------
# GCS_BUCKET=
# GCS_PROJECT_ID=
# 宿主机 JSON 路径（与 docker-compose 中 GCS bind mount 一致；未用 GCS 请从 compose 移除对应 volume）
# GCS_CREDENTIALS_FILE=./web/gcs-credentials.json
# 容器内默认读取：
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs-credentials.json
# 如需覆盖，可显式设置为其他容器内路径

# ---------- Worker ----------
WORKER_POLL_INTERVAL=15000

# ---------- 管理端 ----------
ADMIN_JWT_SECRET=请使用 openssl rand -base64 32 生成
# 浏览器访问管理后台的 Origin；内网多台机器可逗号分隔，例如：
# CORS_ORIGIN=http://192.168.1.100:8080,http://10.0.0.5:8080
CORS_ORIGIN=http://localhost:8080
ADMIN_WEB_PORT=8080
